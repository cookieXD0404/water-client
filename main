local WaterLib = {}
WaterLib.__index = WaterLib

local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Stats = game:GetService("Stats")

function WaterLib.new()
    local self = setmetatable({}, WaterLib)
    
    self.Visible = false
    self.Settings = {ShowHUD = true}
    
    -- UI Elemente
    self.Menu = Drawing.new("Square")
    self.Menu.Size = Vector2.new(400, 300)
    self.Menu.Position = Vector2.new(200, 200)
    self.Menu.Color = Color3.fromRGB(30, 30, 30)
    self.Menu.Visible = false
    
    self.HUD = Drawing.new("Text")
    self.HUD.Size = 18
    self.HUD.Position = Vector2.new(10, 10)
    self.HUD.Color = Color3.fromRGB(255, 255, 255)
    self.HUD.Visible = true
    self.HUD.Font = 2

    self:SetupEvents()
    self:StartLoop()
    
    return self
end

function WaterLib:SetupEvents()
    UIS.InputBegan:Connect(function(input, gpe)
        if input.KeyCode == Enum.KeyCode.RightShift then
            self.Visible = not self.Visible
            self.Menu.Visible = self.Visible
            
            -- HUD Logik: Sichtbar, wenn Menü zu UND Settings auf an
            if self.Settings.ShowHUD then
                self.HUD.Visible = not self.Visible
            end
        end
    end)
end

function WaterLib:StartLoop()
    RunService.RenderStepped:Connect(function()
        if self.Settings.ShowHUD and not self.Visible then
            local fps = math.round(1 / RunService.RenderStepped:Wait())
            local ping = math.round(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
            local char = game.Players.LocalPlayer.Character
            local pos = char and char.HumanoidRootPart.Position or Vector3.new(0,0,0)
            
            self.HUD.Text = string.format("FPS: %d | Ping: %dms | Pos: %d, %d, %d", 
                fps, ping, math.floor(pos.X), math.floor(pos.Y), math.floor(pos.Z))
        end
    end)
end

return WaterLib


