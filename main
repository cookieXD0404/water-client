local WaterLib = {}
WaterLib.__index = WaterLib

local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

function WaterLib.new()
    local self = setmetatable({}, WaterLib)
    
    self.Visible = false
    self.Settings = {ShowHUD = true}
    
    -- Haupt-Menü Fenster
    self.Menu = Drawing.new("Square")
    self.Menu.Size = Vector2.new(400, 300)
    self.Menu.Position = Vector2.new(200, 200)
    self.Menu.Color = Color3.fromRGB(30, 30, 30)
    self.Menu.Visible = false
    
    -- HUD Text (FPS/Ping/Pos)
    self.HUD = Drawing.new("Text")
    self.HUD.Visible = true
    self.HUD.Position = Vector2.new(10, 10)
    
    -- Dragging Variablen
    self.Dragging = false
    self.DragOffset = Vector2.new(0, 0)

    self:SetupEvents()
    return self
end

function WaterLib:SetupEvents()
    -- Input: Toggle Menu (RightShift)
    UIS.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.KeyCode == Enum.KeyCode.RightShift then
            self.Visible = not self.Visible
            self.Menu.Visible = self.Visible
            
            -- HUD Logik: Wenn Menü offen, HUD aus. Wenn Menü zu, HUD an (wenn Setting aktiv)
            if self.Settings.ShowHUD then
                self.HUD.Visible = not self.Visible
            end
        end
    end)

    -- Dragging Logik
    UIS.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local mPos = UIS:GetMouseLocation()
            if mPos.X >= self.Menu.Position.X and mPos.X <= self.Menu.Position.X + self.Menu.Size.X and
               mPos.Y >= self.Menu.Position.Y and mPos.Y <= self.Menu.Position.Y + 25 then
                self.Dragging = true
                self.DragOffset = mPos - self.Menu.Position
            end
        end
    end)

    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            self.Dragging = false
        end
    end)

    RunService.RenderStepped:Connect(function()
        if self.Dragging then
            self.Menu.Position = UIS:GetMouseLocation() - self.DragOffset
        end
    end)
end

return WaterLib
